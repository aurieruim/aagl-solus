[Desktop Entry]
Name=An Anime Game Launcher
Comment=An Launcher for a specific anime game with auto-patching, discord rpc and time tracking
Exec=/usr/bin/anime-game-launcher
Terminal=false
Type=Application
Icon=/usr/share/icons/moe.launcher.an-anime-game-launcher.png
StartupWMClass=moe.launcher.an-anime-game-launcher
Categories=Game
